<main class="flex-1 lg:ml-64 p-4 md:p-5 bg-white min-h-screen overflow-x-hidden">
  <!-- Mobile Header -->
  <div class="lg:hidden flex items-center justify-between mb-6 bg-muted rounded-card p-4">
    <button onclick="toggleSidebar()" aria-label="Abrir menu" class="p-2 rounded-lg hover:bg-gray-200 cursor-pointer transition-all duration-200">
      <i data-lucide="menu" class="w-6 h-6 text-foreground"></i>
    </button>
    <h1 class="text-foreground text-lg font-bold">Confer</h1>
    <div class="w-10"></div>
  </div>

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6 md:mb-8">
    <div>
      <h1 class="text-foreground text-2xl md:text-3xl font-bold mb-1">Importações</h1>
      <p class="text-foreground text-sm text-gray-500 mt-1">Histórico de importações do sistema</p>
    </div>
  </div>

  <!-- Table Card -->
  <div class="bg-muted rounded-card pt-5 px-3 pb-3 mb-6 md:mb-8">
    <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Lista de importações</h3>
    <div class="bg-white rounded-card overflow-hidden border border-border">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Tipo</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Arquivo</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Data</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Erros</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-foreground uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-border">
            <% @importacoes.each do |importacao| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-foreground">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= importacao.tipo == 'produto' ? 'bg-primary/10 text-primary' : 'bg-muted text-foreground' %>">
                    <%= importacao.tipo == 'produto' ? 'Produto' : 'Operação' %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-foreground">
                  <%= importacao.status %>
                </td>
                <td class="px-6 py-4 text-sm text-foreground max-w-xs truncate" title="<%= importacao.relatorio %>">
                  <%= link_to importacao.relatorio, importacao.relatorio, target: '_blank' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-foreground">
                  <%= l(importacao.created_at, format: :short) if importacao.created_at.present? %>
                </td>
                <td class="px-6 py-4 text-sm text-foreground max-w-xs truncate" title="<%= importacao.erros %>">
                  <%= importacao.erros.presence || "—" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to importacao_path(importacao), class: 'p-2 text-foreground hover:text-primary hover:bg-muted/50 rounded-card transition-colors', title: 'Visualizar' do %>
                      <i data-lucide="eye" class="w-5 h-5"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @importacoes.respond_to?(:total_pages) && @importacoes.total_pages > 1 %>
        <div class="px-6 py-4 border-t border-border">
          <div class="apple_pagination flex items-center justify-center">
            <%= will_paginate @importacoes, container: false, class: 'flex items-center gap-2' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</main>