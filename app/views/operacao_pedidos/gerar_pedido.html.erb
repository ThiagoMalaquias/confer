<main class="flex-1 lg:ml-64 p-4 md:p-5 bg-white min-h-screen overflow-x-hidden">
  <div class="lg:hidden flex items-center justify-between mb-6 bg-muted rounded-card p-4">
    <button onclick="toggleSidebar()" aria-label="Abrir menu" class="p-2 rounded-lg hover:bg-gray-200 cursor-pointer transition-all duration-200">
      <i data-lucide="menu" class="w-6 h-6 text-foreground"></i>
    </button>
    <h1 class="text-foreground text-lg font-bold">Confer</h1>
    <div class="w-10"></div>
  </div>

  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6 md:mb-8">
    <div class="flex items-center gap-4">
      <%= link_to operacao_pedidos_path, class: 'inline-flex items-center gap-2 px-4 py-2 text-foreground bg-white border border-border rounded-button hover:bg-muted/50 transition-colors' do %>
        <i data-lucide="arrow-left" class="w-5 h-5"></i>
        Voltar
      <% end %>
      <div>
        <h1 class="text-foreground text-2xl md:text-3xl font-bold mb-1">Gerar pedido — Operação <%= @operacao.numero %></h1>
        <p class="text-foreground text-sm text-gray-500 mt-1">Adicione os itens do pedido (EAN, lote, vencimento, fabricação e prazo)</p>
      </div>
    </div>
  </div>

  <%= form_with model: @operacao_pedido, url: operacao_pedido_path(@operacao_pedido), method: :patch, html: { class: "space-y-6", role: "form" } do |f| %>
    <% if @operacao_pedido.errors.any? %>
      <div class="text-sm rounded-button p-4 bg-error-light text-error-dark border border-error/20" role="alert">
        <ul class="list-disc list-inside text-sm">
          <% @operacao_pedido.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Visualização: número da op, observação, quantidade da op, administrador -->
    <div class="bg-muted rounded-card pt-5 px-3 pb-3">
      <h2 class="text-foreground text-lg font-bold ml-3 mb-4 pb-2 border-b border-border">Dados da operação</h2>
      <div class="bg-white rounded-card p-4 md:p-5 border border-border">
        <dl class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Número da operação</dt>
            <dd class="mt-1 text-sm font-medium text-foreground"><%= @operacao.numero %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Quantidade da operação</dt>
            <dd class="mt-1 text-sm font-medium text-foreground"><%= @operacao.qtd %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Usuário</dt>
            <dd class="mt-1 text-sm font-medium text-foreground"><%= @operacao_pedido.administrador&.nome.presence || "—" %></dd>
          </div>
          <div class="md:col-span-2 lg:col-span-4">
            <dt class="text-sm font-medium text-gray-500">Observação</dt>
            <dd class="mt-1 p-3 rounded-button bg-primary/5 border border-primary/20 text-sm text-foreground"><%= @operacao.observacao.presence || "—" %></dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Adicionar item: EAN + lote, vencimento, fabricação, prazo -->
    <div data-controller="pedido-itens" data-pedido-itens-url-value="<%= buscar_por_ean_produtos_path %>">
      <h2 class="text-foreground text-lg font-bold mb-3">Itens do pedido</h2>
      <div class="flex flex-wrap items-end gap-3 mb-4 pb-4 border-b border-border">
        <div class="flex-1 min-w-[140px]">
          <label for="ean-add" class="block text-sm font-medium text-foreground mb-1">EAN do produto</label>
          <input type="text"
                 id="ean-add"
                 data-pedido-itens-target="eanInput"
                 data-action="keydown.enter->pedido-itens#addByEan"
                 placeholder="EAN (Enter para adicionar)"
                 class="w-full h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm"
                 autocomplete="off">
        </div>
        <div class="w-32">
          <label for="lote-add" class="block text-sm font-medium text-foreground mb-1">Lote</label>
          <input type="text" id="lote-add" data-pedido-itens-target="loteInput" placeholder="Lote"
                 class="w-full h-11 px-3 rounded-button border border-border text-foreground focus:ring-2 focus:ring-primary/20 text-sm">
        </div>
        <div class="w-36">
          <label for="vencimento-add" class="block text-sm font-medium text-foreground mb-1">Vencimento</label>
          <input type="date" id="vencimento-add" data-pedido-itens-target="vencimentoInput"
                 class="w-full h-11 px-3 rounded-button border border-border text-foreground focus:ring-2 focus:ring-primary/20 text-sm">
        </div>
        <div class="w-32">
          <label for="fabricacao-add" class="block text-sm font-medium text-foreground mb-1">Fabricação</label>
          <input type="text" id="fabricacao-add" data-pedido-itens-target="fabricacaoInput" placeholder="Fabricação"
                 class="w-full h-11 px-3 rounded-button border border-border text-foreground focus:ring-2 focus:ring-primary/20 text-sm">
        </div>
        <div class="w-28">
          <label for="prazo-add" class="block text-sm font-medium text-foreground mb-1">Prazo</label>
          <input type="text" id="prazo-add" data-pedido-itens-target="prazoInput" placeholder="Prazo"
                 class="w-full h-11 px-3 rounded-button border border-border text-foreground focus:ring-2 focus:ring-primary/20 text-sm">
        </div>
        <button type="button"
                data-action="click->pedido-itens#addByEan"
                class="h-11 px-4 rounded-button bg-primary hover:bg-primary-hover text-white inline-flex items-center justify-center gap-2 shrink-0">
          <i data-lucide="plus" class="w-5 h-5"></i>
          Adicionar
        </button>
      </div>

      <div class="border border-border rounded-card overflow-hidden">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Código / Descrição</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">EAN</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Lote</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Vencimento</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Fabricação</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Prazo</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-foreground uppercase tracking-wider w-20">Ações</th>
            </tr>
          </thead>
          <tbody data-pedido-itens-target="container">
            <% @operacao_pedido.operacao_pedido_itens.each_with_index do |item, idx| %>
              <tr data-item-row class="border-t border-border">
                <td class="px-4 py-2">
                  <%= text_field_tag "operacao_pedido[operacao_pedido_itens_attributes][#{idx}][codigo]", item.codigo, readonly: true, class: "w-full h-10 px-3 rounded-button border border-border bg-muted/30 text-foreground text-sm" %>
                  <%= hidden_field_tag "operacao_pedido[operacao_pedido_itens_attributes][#{idx}][descricao]", item.descricao %>
                  <%= hidden_field_tag "operacao_pedido[operacao_pedido_itens_attributes][#{idx}][id]", item.id if item.persisted? %>
                </td>
                <td class="px-4 py-2"><%= item.codigo %></td>
                <td class="px-4 py-2">
                  <%= text_field_tag "operacao_pedido[operacao_pedido_itens_attributes][#{idx}][lote]", item.lote, class: "w-full h-10 px-3 rounded-button border border-border text-foreground text-sm" %>
                </td>
                <td class="px-4 py-2">
                  <%= text_field_tag "operacao_pedido[operacao_pedido_itens_attributes][#{idx}][vencimento]", item.vencimento&.strftime("%Y-%m-%d"), type: "date", class: "w-full h-10 px-3 rounded-button border border-border text-foreground text-sm" %>
                </td>
                <td class="px-4 py-2">
                  <%= text_field_tag "operacao_pedido[operacao_pedido_itens_attributes][#{idx}][fabricacao]", item.fabricacao, class: "w-full h-10 px-3 rounded-button border border-border text-foreground text-sm" %>
                </td>
                <td class="px-4 py-2">
                  <%= text_field_tag "operacao_pedido[operacao_pedido_itens_attributes][#{idx}][prazo]", item.prazo, class: "w-full h-10 px-3 rounded-button border border-border text-foreground text-sm" %>
                </td>
                <td class="px-4 py-2 text-right">
                  <% if item.persisted? %>
                    <%= hidden_field_tag "operacao_pedido[operacao_pedido_itens_attributes][#{idx}][_destroy]", "0", id: nil %>
                    <button type="button" data-action="click->pedido-itens#removeRow" class="p-2 text-foreground hover:text-red-600 hover:bg-red-50 rounded-card transition-colors" title="Remover"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                  <% else %>
                    <button type="button" data-action="click->pedido-itens#removeRow" class="p-2 text-foreground hover:text-red-600 hover:bg-red-50 rounded-card transition-colors" title="Remover"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <template data-pedido-itens-target="rowTemplate">
          <tr data-item-row class="border-t border-border">
            <td class="px-4 py-2">
              <input type="text" name="operacao_pedido[operacao_pedido_itens_attributes][__INDEX__][codigo]" readonly class="w-full h-10 px-3 rounded-button border border-border bg-muted/30 text-foreground text-sm">
              <input type="hidden" name="operacao_pedido[operacao_pedido_itens_attributes][__INDEX__][descricao]">
            </td>
            <td class="px-4 py-2 ean-cell"></td>
            <td class="px-4 py-2">
              <input type="text" name="operacao_pedido[operacao_pedido_itens_attributes][__INDEX__][lote]" class="w-full h-10 px-3 rounded-button border border-border text-foreground text-sm">
            </td>
            <td class="px-4 py-2">
              <input type="date" name="operacao_pedido[operacao_pedido_itens_attributes][__INDEX__][vencimento]" class="w-full h-10 px-3 rounded-button border border-border text-foreground text-sm">
            </td>
            <td class="px-4 py-2">
              <input type="text" name="operacao_pedido[operacao_pedido_itens_attributes][__INDEX__][fabricacao]" class="w-full h-10 px-3 rounded-button border border-border text-foreground text-sm">
            </td>
            <td class="px-4 py-2">
              <input type="text" name="operacao_pedido[operacao_pedido_itens_attributes][__INDEX__][prazo]" class="w-full h-10 px-3 rounded-button border border-border text-foreground text-sm">
            </td>
            <td class="px-4 py-2 text-right">
              <button type="button" data-action="click->pedido-itens#removeRow" class="p-2 text-foreground hover:text-red-600 hover:bg-red-50 rounded-card transition-colors" title="Remover"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
            </td>
          </tr>
        </template>
      </div>
    </div>

    <div class="flex justify-end gap-4 pt-4 border-t border-border">
      <%= link_to operacao_pedidos_path, class: 'px-6 py-2 rounded-button border border-border text-foreground font-medium hover:bg-muted/50 transition-colors' do %>Cancelar<% end %>
      <%= f.submit "Baixar OP", class: "px-6 py-2 rounded-button bg-primary hover:bg-primary-hover text-white font-medium transition-colors shadow-sm" %>
    </div>
  <% end %>
</main>