<% operacao_pedido = @operacao.operacao_pedidos.first %>
<% itens = operacao_pedido&.operacao_pedido_itens.order(:descricao) || [] %>

<div style="margin:0; padding:24px; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#111827;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:800px; margin:0 auto; background:#ffffff; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden;">
    <tr>
      <td style="padding:20px 24px; background:#111827; color:#ffffff;">
        <h1 style="margin:0; font-size:20px; line-height:1.3;">Operacao baixada com sucesso</h1>
        <p style="margin:6px 0 0; font-size:13px; color:#d1d5db;">Confer - Resumo da baixa de pedido</p>
      </td>
    </tr>

    <tr>
      <td style="padding:20px 24px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:separate; border-spacing:0;">
          <tr>
            <td style="width:33.33%; padding:12px; border:1px solid #e5e7eb; border-radius:8px; background:#f9fafb;">
              <p style="margin:0; font-size:12px; color:#6b7280;">Pedido</p>
              <p style="margin:6px 0 0; font-size:16px; font-weight:700; color:#111827;"><%= @operacao.pedido_venda.presence || "—" %></p>
            </td>
            <td style="width:12px;"></td>
            <td style="width:33.33%; padding:12px; border:1px solid #e5e7eb; border-radius:8px; background:#f9fafb;">
              <p style="margin:0; font-size:12px; color:#6b7280;">Qtd da operacao</p>
              <p style="margin:6px 0 0; font-size:16px; font-weight:700; color:#111827;"><%= @operacao.qtd.presence || "—" %></p>
            </td>
            <td style="width:12px;"></td>
            <td style="width:33.33%; padding:12px; border:1px solid #e5e7eb; border-radius:8px; background:#f9fafb;">
              <p style="margin:0; font-size:12px; color:#6b7280;">Data da baixa</p>
              <p style="margin:6px 0 0; font-size:16px; font-weight:700; color:#111827;"><%= Time.current.strftime("%d/%m/%Y %H:%M") %></p>
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <tr>
      <td style="padding:0 24px 24px;">
        <h2 style="margin:0 0 12px; font-size:16px; color:#111827;">Itens do pedido</h2>

        <% if itens.any? %>
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden;">
            <thead>
              <tr style="background:#f3f4f6;">
                <th align="left" style="padding:10px 12px; border-bottom:1px solid #e5e7eb; font-size:12px; color:#374151;">Codigo</th>
                <th align="left" style="padding:10px 12px; border-bottom:1px solid #e5e7eb; font-size:12px; color:#374151;">Descricao</th>
                <th align="left" style="padding:10px 12px; border-bottom:1px solid #e5e7eb; font-size:12px; color:#374151;">Lote</th>
                <th align="left" style="padding:10px 12px; border-bottom:1px solid #e5e7eb; font-size:12px; color:#374151;">Vencimento</th>
                <th align="left" style="padding:10px 12px; border-bottom:1px solid #e5e7eb; font-size:12px; color:#374151;">Fabricacao</th>
                <th align="left" style="padding:10px 12px; border-bottom:1px solid #e5e7eb; font-size:12px; color:#374151;">Prazo</th>
              </tr>
            </thead>
            <tbody>
              <% itens.each do |item| %>
                <tr>
                  <td style="padding:10px 12px; border-bottom:1px solid #f3f4f6; font-size:13px; color:#111827;"><%= item.codigo.presence || "—" %></td>
                  <td style="padding:10px 12px; border-bottom:1px solid #f3f4f6; font-size:13px; color:#111827;"><%= item.descricao.presence || "—" %></td>
                  <td style="padding:10px 12px; border-bottom:1px solid #f3f4f6; font-size:13px; color:#111827;"><%= item.lote.presence || "—" %></td>
                  <td style="padding:10px 12px; border-bottom:1px solid #f3f4f6; font-size:13px; color:#111827;"><%= item.vencimento&.strftime("%d/%m/%Y") || "—" %></td>
                  <td style="padding:10px 12px; border-bottom:1px solid #f3f4f6; font-size:13px; color:#111827;"><%= item.fabricacao.presence || "—" %></td>
                  <td style="padding:10px 12px; border-bottom:1px solid #f3f4f6; font-size:13px; color:#111827;"><%= item.prazo.presence || "—" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div style="padding:14px; border:1px dashed #d1d5db; border-radius:8px; font-size:13px; color:#6b7280; background:#fafafa;">
            Nenhum item encontrado para este pedido.
          </div>
        <% end %>
      </td>
    </tr>

    <tr>
      <td style="padding:14px 24px; background:#f9fafb; border-top:1px solid #e5e7eb; font-size:12px; color:#6b7280;">
        Email automatico enviado pelo sistema Confer.
      </td>
    </tr>
  </table>
</div>