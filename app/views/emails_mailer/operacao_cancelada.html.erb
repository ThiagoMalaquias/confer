<div style="margin:0; padding:24px; background-color:#f3f4f6; font-family:Arial, Helvetica, sans-serif; color:#111827;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:800px; margin:0 auto; background:#ffffff; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden;">
    <tr>
      <td style="padding:20px 24px; background:#7f1d1d; color:#ffffff;">
        <h1 style="margin:0; font-size:20px; line-height:1.3;">OP cancelada</h1>
        <p style="margin:6px 0 0; font-size:13px; color:#fecaca;">Confer - Notificação de cancelamento de pedido</p>
      </td>
    </tr>

    <tr>
      <td style="padding:20px 24px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:separate; border-spacing:0;">
          <tr>
            <td style="width:33.33%; padding:12px; border:1px solid #e5e7eb; border-radius:8px; background:#f9fafb;">
              <p style="margin:0; font-size:12px; color:#6b7280;">Pedido</p>
              <p style="margin:6px 0 0; font-size:16px; font-weight:700; color:#111827;"><%= @operacao.pedido_venda.presence || "—" %></p>
            </td>
            <td style="width:12px;"></td>
            <td style="width:33.33%; padding:12px; border:1px solid #e5e7eb; border-radius:8px; background:#f9fafb;">
              <p style="margin:0; font-size:12px; color:#6b7280;">Qtd</p>
              <p style="margin:6px 0 0; font-size:16px; font-weight:700; color:#111827;"><%= @operacao.qtd.presence || "—" %></p>
            </td>
            <td style="width:12px;"></td>
            <td style="width:33.33%; padding:12px; border:1px solid #e5e7eb; border-radius:8px; background:#f9fafb;">
              <p style="margin:0; font-size:12px; color:#6b7280;">Data do cancelamento</p>
              <p style="margin:6px 0 0; font-size:16px; font-weight:700; color:#111827;"><%= Time.current.strftime("%d/%m/%Y %H:%M") %></p>
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <tr>
      <td style="padding:0 24px 20px;">
        <div style="padding:12px; border:1px solid #fecaca; background:#fef2f2; color:#991b1b; border-radius:8px; font-size:13px;">
          Esta operação foi cancelada. Os itens vinculados ao pedido foram removidos.
        </div>
      </td>
    </tr>

    <tr>
      <td style="padding:14px 24px; background:#f9fafb; border-top:1px solid #e5e7eb; font-size:12px; color:#6b7280;">
        Email automático enviado pelo sistema Confer.
      </td>
    </tr>
  </table>
</div>