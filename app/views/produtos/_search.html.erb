<div class="bg-white rounded-card p-4 md:p-5 border border-border mb-3">
  <%= form_with url: produtos_path, method: :get, local: true, class: "space-y-4 md:space-y-0 md:flex md:flex-wrap md:items-end md:gap-4" do %>
    <div class="flex flex-col gap-1">
      <label for="codigo" class="text-sm font-medium text-foreground">Código</label>
      <input type="text"
             id="codigo"
             name="codigo"
             value="<%= params[:codigo] %>"
             placeholder="Ex: 1234"
             class="w-full md:w-40 h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
    </div>

    <div class="flex flex-col gap-1">
      <label for="ean" class="text-sm font-medium text-foreground">EAN</label>
      <input type="text"
             id="ean"
             name="ean"
             value="<%= params[:ean] %>"
             placeholder="Ex: 789..."
             class="w-full md:w-44 h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
    </div>

    <div class="flex flex-col gap-1">
      <label for="descricao" class="text-sm font-medium text-foreground">Descrição</label>
      <input type="text"
             id="descricao"
             name="descricao"
             value="<%= params[:descricao] %>"
             placeholder="Parte do nome do produto"
             class="w-full md:w-72 h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
    </div>

    <div class="flex flex-col gap-1">
      <label for="unc" class="text-sm font-medium text-foreground">Unidade</label>
      <input type="text"
             id="unc"
             name="unc"
             value="<%= params[:unc] %>"
             placeholder="Ex: UN, CX..."
             class="w-full md:w-40 h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary">
    </div>

    <div class="flex gap-2">
      <button type="submit" class="h-11 px-4 rounded-button bg-primary hover:bg-primary-hover text-white font-medium inline-flex items-center gap-2">
        <i data-lucide="search" class="w-5 h-5"></i>
        Filtrar
      </button>

      <%= link_to produtos_path(limpar: 1), class: "h-11 px-4 rounded-button border border-border text-foreground font-medium inline-flex items-center gap-2 hover:bg-muted/50" do %>
        Limpar
      <% end %>
    </div>
  <% end %>
</div>