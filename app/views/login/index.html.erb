<% content_for :page_title, "Entrar" %>

<div class="mb-8 text-center">
  <div class="inline-flex items-center justify-center rounded-xl bg-muted/50 mb-6 ring-1 ring-border/50">
    <%= image_tag "/assets/images/logo.png", alt: "Logo", class: "h-30 w-auto object-contain select-none" %>
  </div>
  <h1 class="text-2xl font-bold text-foreground">Acessar painel</h1>
  <p class="text-sm text-gray-500 mt-1">Informe seu e-mail e senha</p>
</div>

<%= form_with url: sign_in_login_index_path, method: :post, local: true, class: "space-y-4" do %>
  <div>
    <label class="block text-sm font-medium mb-1" for="email">E-mail</label>
    <input
      id="email"
      name="email"
      type="email"
      required
      class="w-full h-11 px-3 rounded-button border border-border focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
      placeholder="voce@empresa.com"
    />
  </div>

  <div>
    <label class="block text-sm font-medium mb-1" for="senha">Senha</label>
    <input
      id="senha"
      name="senha"
      type="password"
      required
      class="w-full h-11 px-3 rounded-button border border-border focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary"
      placeholder="••••••••"
    />
  </div>

  <% if flash[:error].present? %>
    <div class="text-sm rounded-button p-3 bg-error-light text-error-dark border border-error/20">
      <%= flash[:error] %>
    </div>
  <% end %>

  <button
    type="submit"
    class="w-full h-11 rounded-button bg-primary text-white font-medium hover:bg-primary-hover transition"
  >
    Entrar
  </button>
<% end %>