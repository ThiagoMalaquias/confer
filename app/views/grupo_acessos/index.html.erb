<main class="flex-1 lg:ml-64 p-4 md:p-5 bg-white min-h-screen overflow-x-hidden">
  <!-- Mobile Header -->
  <div class="lg:hidden flex items-center justify-between mb-6 bg-muted rounded-card p-4">
    <button onclick="toggleSidebar()" aria-label="Abrir menu" class="p-2 rounded-lg hover:bg-gray-200 cursor-pointer transition-all duration-200">
      <i data-lucide="menu" class="w-6 h-6 text-foreground"></i>
    </button>
    <h1 class="text-foreground text-lg font-bold">Confer</h1>
    <div class="w-10"></div>
  </div>

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6 md:mb-8">
    <div>
      <h1 class="text-foreground text-2xl md:text-3xl font-bold mb-1">Grupos de Acessos</h1>
      <p class="text-foreground text-sm text-gray-500 mt-1">Gerencie os grupos de permissões do sistema</p>
    </div>
    <%= link_to new_grupo_acesso_path, class: 'inline-flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded-button font-medium transition-colors shadow-sm' do %>
      <i data-lucide="plus" class="w-5 h-5"></i>
      Novo Grupo
    <% end %>
  </div>

  <!-- Table Card -->
  <div class="bg-muted rounded-card pt-5 px-3 pb-3 mb-6 md:mb-8">
    <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Lista de grupos de acessos</h3>
    <div class="bg-white rounded-card overflow-hidden border border-border">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Nome</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Nº de Acessos</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Nº de Usuarios Internos</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-foreground uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-border">
            <% @grupo_acessos.each do |grupo_acesso| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-foreground">
                  <%= link_to grupo_acesso_path(grupo_acesso), class: 'hover:text-primary transition-colors' do %>
                    <%= grupo_acesso.nome %>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-foreground">
                  <% acessos_count = grupo_acesso.acessos_actions.count %>
                  <% if acessos_count > 0 %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary">
                      <%= acessos_count %> acesso<%= 's' if acessos_count != 1 %>
                    </span>
                  <% else %>
                    <span class="text-gray-500">Nenhum acesso</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-foreground">
                  <% usuarios_internos_count = grupo_acesso.administrador_grupo_acessos.count %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-muted text-foreground">
                    <%= usuarios_internos_count %> usuario interno<%= 's' if usuarios_internos_count != 1 %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to grupo_acesso_path(grupo_acesso), class: 'p-2 text-foreground hover:text-primary hover:bg-muted/50 rounded-card transition-colors', title: 'Visualizar' do %>
                      <i data-lucide="eye" class="w-5 h-5"></i>
                    <% end %>
                    <%= link_to edit_grupo_acesso_path(grupo_acesso), class: 'p-2 text-foreground hover:text-primary hover:bg-muted/50 rounded-card transition-colors', title: 'Editar' do %>
                      <i data-lucide="pencil" class="w-5 h-5"></i>
                    <% end %>
                    <%= link_to grupo_acesso_path(grupo_acesso), method: :delete, data: { confirm: 'Tem certeza que deseja excluir este grupo de acessos?' }, class: 'p-2 text-foreground hover:text-red-600 hover:bg-red-50 rounded-card transition-colors', title: 'Excluir' do %>
                      <i data-lucide="trash-2" class="w-5 h-5"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @grupo_acessos.respond_to?(:total_pages) && @grupo_acessos.total_pages > 1 %>
        <div class="px-6 py-4 border-t border-border">
          <div class="flex items-center justify-center">
            <%= will_paginate @grupo_acessos, container: false, class: 'flex items-center gap-2' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</main>