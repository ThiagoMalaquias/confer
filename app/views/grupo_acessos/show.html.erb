<main class="flex-1 lg:ml-64 p-4 md:p-5 bg-white min-h-screen overflow-x-hidden">
  <!-- Mobile Header -->
  <div class="lg:hidden flex items-center justify-between mb-6 bg-muted rounded-card p-4">
    <button onclick="toggleSidebar()" aria-label="Abrir menu" class="p-2 rounded-lg hover:bg-gray-200 cursor-pointer transition-all duration-200">
      <i data-lucide="menu" class="w-6 h-6 text-foreground"></i>
    </button>
    <h1 class="text-foreground text-lg font-bold">Confer</h1>
    <div class="w-10"></div>
  </div>

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6 md:mb-8">
    <div class="flex items-center gap-4">
      <%= link_to grupo_acessos_path, class: 'inline-flex items-center gap-2 px-4 py-2 text-foreground bg-white border border-border rounded-button hover:bg-muted/50 transition-colors' do %>
        <i data-lucide="arrow-left" class="w-5 h-5"></i>
        Voltar
      <% end %>
      <div>
        <h1 class="text-foreground text-2xl md:text-3xl font-bold mb-1"><%= @grupo_acesso.nome %></h1>
        <p class="text-foreground text-sm text-gray-500 mt-1">Detalhes do grupo de acessos</p>
      </div>
    </div>
    <%= link_to edit_grupo_acesso_path(@grupo_acesso), class: 'inline-flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded-button font-medium transition-colors shadow-sm' do %>
      <i data-lucide="pencil" class="w-5 h-5"></i>
      Editar
    <% end %>
  </div>

  <!-- Cards -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6 md:mb-8">
    <!-- Card: Informações Básicas -->
    <div class="bg-muted rounded-card pt-5 px-3 pb-3">
      <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Informações Básicas</h3>
      <div class="bg-white rounded-card p-4 md:p-5 border border-border">
        <dl class="space-y-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Nome</dt>
            <dd class="mt-1 text-sm font-medium text-foreground"><%= @grupo_acesso.nome %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Total de Acessos</dt>
            <dd class="mt-1">
              <% acessos_count = @grupo_acesso.acessos_actions.count %>
              <% if acessos_count > 0 %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-primary/10 text-primary">
                  <%= acessos_count %> acesso<%= 's' if acessos_count != 1 %>
                </span>
              <% else %>
                <span class="text-sm text-gray-500">Nenhum acesso configurado</span>
              <% end %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Total de Usuarios Internos</dt>
            <dd class="mt-1">
              <% usuarios_internos_count = @grupo_acesso.administrador_grupo_acessos.count %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-muted text-foreground">
                <%= usuarios_internos_count %> usuario interno<%= 's' if usuarios_internos_count != 1 %>
              </span>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Card: Administradores -->
    <div class="bg-muted rounded-card pt-5 px-3 pb-3">
      <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Usuarios Internos</h3>
      <div class="bg-white rounded-card p-4 md:p-5 border border-border">
        <% if @grupo_acesso.administrador_grupo_acessos.any? %>
          <div class="space-y-2">
            <% @grupo_acesso.administrador_grupo_acessos.each do |aga| %>
              <div class="flex items-center justify-between p-3 bg-muted/30 rounded-card">
                <span class="text-sm font-medium text-foreground">
                  <%= aga.administrador.nome %>
                </span>
                <%= link_to administrador_path(aga.administrador), class: 'p-2 text-foreground hover:text-primary hover:bg-muted/50 rounded-card transition-colors' do %>
                  <i data-lucide="external-link" class="w-4 h-4"></i>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">Nenhum usuario interno atribuído a este grupo</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Acessos -->
  <% if @grupo_acesso.acessos_actions.any? %>
    <div class="bg-muted rounded-card pt-5 px-3 pb-3 mb-6 md:mb-8">
      <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Permissões e Acessos (<%= @grupo_acesso.acessos_actions.count %>)</h3>
      <div class="bg-white rounded-card p-4 md:p-5 border border-border">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
          <% @grupo_acesso.acessos_actions.uniq.each do |acesso| %>
            <div class="flex items-center gap-2 p-2 bg-success-light rounded-card">
              <i data-lucide="check" class="w-4 h-4 text-success flex-shrink-0"></i>
              <span class="text-sm text-foreground"><%= acesso %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</main>