<main class="flex-1 lg:ml-64 p-4 md:p-5 bg-white min-h-screen overflow-x-hidden">
  <!-- Mobile Header -->
  <div class="lg:hidden flex items-center justify-between mb-6 bg-muted rounded-card p-4">
    <button onclick="toggleSidebar()" aria-label="Abrir menu" class="p-2 rounded-lg hover:bg-gray-200 cursor-pointer transition-all duration-200">
      <i data-lucide="menu" class="w-6 h-6 text-foreground"></i>
    </button>
    <h1 class="text-foreground text-lg font-bold">Confer</h1>
    <div class="w-10"></div>
  </div>

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6 md:mb-8" data-controller="importacao-upload" data-importacao-upload-tipo-value="operacao">
    <div>
      <h1 class="text-foreground text-2xl md:text-3xl font-bold mb-1">Operações</h1>
      <p class="text-foreground text-sm text-gray-500 mt-1">Gerencie as operações do sistema</p>
    </div>
    <div class="flex items-center gap-2">
      <%= form_with url: importacoes_path, method: :post, local: true, html: { multipart: true, class: "inline", data: { importacao_upload_target: "form" } } do |f| %>
        <%= hidden_field_tag "importacao[tipo]", "operacao", data: { importacao_upload_target: "tipoInput" } %>
        <input type="file" name="relatorio" accept=".pdf" class="hidden" data-importacao-upload-target="fileInput" data-action="change->importacao-upload#submit">
      <% end %>
      <button type="button" data-action="click->importacao-upload#open" class="inline-flex items-center gap-2 px-4 py-2 rounded-button border border-border text-foreground font-medium hover:bg-muted/50 transition-colors shadow-sm">
        <i data-lucide="upload" class="w-5 h-5"></i>
        Importação
      </button>
      <%= link_to new_operacao_path, class: 'inline-flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded-button font-medium transition-colors shadow-sm' do %>
        <i data-lucide="plus" class="w-5 h-5"></i>
        Nova Operação
      <% end %>
    </div>
  </div>

  <!-- Table Card -->
  <div class="bg-muted rounded-card pt-5 px-3 pb-3 mb-6 md:mb-8">
    <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Lista de operações</h3>
    <div class="bg-white rounded-card overflow-hidden border border-border">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Número</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Pedido de Venda</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Qtd</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Observação</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-foreground uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-border">
            <% @operacoes.each do |operacao| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-foreground">
                  <%= link_to operacao_path(operacao), class: 'hover:text-primary transition-colors' do %>
                    <%= operacao.numero %>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-foreground">
                  <%= operacao.pedido_venda %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-foreground">
                  <%= operacao.qtd %>
                </td>
                <td class="px-6 py-4 text-sm text-foreground max-w-xs truncate" title="<%= operacao.observacao %>">
                  <%= operacao.observacao %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to operacao_path(operacao), class: 'p-2 text-foreground hover:text-primary hover:bg-muted/50 rounded-card transition-colors', title: 'Visualizar' do %>
                      <i data-lucide="eye" class="w-5 h-5"></i>
                    <% end %>
                    <%= link_to edit_operacao_path(operacao), class: 'p-2 text-foreground hover:text-primary hover:bg-muted/50 rounded-card transition-colors', title: 'Editar' do %>
                      <i data-lucide="pencil" class="w-5 h-5"></i>
                    <% end %>
                    <%= link_to operacao_path(operacao), method: :delete, data: { confirm: 'Tem certeza que deseja excluir esta operação?' }, class: 'p-2 text-foreground hover:text-red-600 hover:bg-red-50 rounded-card transition-colors', title: 'Excluir' do %>
                      <i data-lucide="trash-2" class="w-5 h-5"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @operacoes.respond_to?(:total_pages) && @operacoes.total_pages > 1 %>
        <div class="px-6 py-4 border-t border-border">
          <div class="apple_pagination flex items-center justify-center">
            <%= will_paginate @operacoes, container: false, class: 'flex items-center gap-2' %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</main>