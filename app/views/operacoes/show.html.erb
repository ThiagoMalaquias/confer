<main class="flex-1 lg:ml-64 p-4 md:p-5 bg-white min-h-screen overflow-x-hidden">
  <!-- Mobile Header -->
  <div class="lg:hidden flex items-center justify-between mb-6 bg-muted rounded-card p-4">
    <button onclick="toggleSidebar()" aria-label="Abrir menu" class="p-2 rounded-lg hover:bg-gray-200 cursor-pointer transition-all duration-200">
      <i data-lucide="menu" class="w-6 h-6 text-foreground"></i>
    </button>
    <h1 class="text-foreground text-lg font-bold">Confer</h1>
    <div class="w-10"></div>
  </div>

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6 md:mb-8">
    <div class="flex items-center gap-4">
      <%= link_to "javascript:history.back()", class: 'inline-flex items-center gap-2 px-4 py-2 text-foreground bg-white border border-border rounded-button hover:bg-muted/50 transition-colors' do %>
        <i data-lucide="arrow-left" class="w-5 h-5"></i>
        Voltar
      <% end %>
      <div>
        <h1 class="text-foreground text-2xl md:text-3xl font-bold mb-1">
          Operação <%= @operacao.numero.present? ? "##{@operacao.numero}" : "" %>
        </h1>
        <p class="text-foreground text-sm text-gray-500">Detalhes da operação</p>
      </div>
    </div>
    <div>
      <%= link_to edit_operacao_path(@operacao), class: 'inline-flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded-button font-medium transition-colors shadow-sm' do %>
        <i data-lucide="pencil" class="w-5 h-5"></i>
        Editar
      <% end %>
      <% if @operacao.status == "CONCLUIDO" %>
        <%= link_to cancelar_operacao_path(@operacao), data: { confirm: 'Tem certeza que deseja cancelar esta operação?' },
            class: "inline-flex items-center gap-2 px-4 h-10 rounded-button text-white text-sm font-medium transition-colors shadow-sm", style: "background-color: #FF0000;" do %>
          <i data-lucide="x" class="w-4 h-4"></i>
          Cancelar
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Card: Informações da Operação -->
  <div class="bg-muted rounded-card pt-5 px-3 pb-3 mb-6 md:mb-8">
    <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Informações da Operação</h3>
    <div class="bg-white rounded-card p-4 md:p-5 border border-border">
      <dl class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
          <dt class="text-sm font-medium text-gray-500">Pedido de Venda</dt>
          <dd class="mt-1 text-sm font-medium text-foreground"><%= @operacao.pedido_venda.presence || "—" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Quantidade</dt>
          <dd class="mt-1 text-sm font-medium text-foreground"><%= @operacao.qtd.presence || "—" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-gray-500">Status</dt>
          <dd class="mt-1 text-sm font-medium text-foreground"><%= @operacao.status.presence || "—" %></dd>
        </div>
        <% if @operacao.observacao.present? %>
          <div class="md:col-span-2">
            <dt class="text-sm font-medium text-gray-500">Observação</dt>
            <dd class="mt-1 text-sm text-foreground"><%= @operacao.observacao %></dd>
          </div>
        <% end %>
        <% if @operacao.status == "ERRO" %>
          <div class="md:col-span-4">
            <dt class="text-sm font-medium text-gray-500 mb-1">Mensagem de erro</dt>

            <dd class="rounded-card border border-error/20 bg-error-light p-4 text-sm text-error-dark">
              <div class="flex items-start gap-2">
                <i data-lucide="alert-triangle" class="w-4 h-4 mt-0.5 shrink-0"></i>
                <span><%= @operacao.mensagem_erro.presence || "—" %></span>
              </div>
            </dd>

            <div class="mt-3">
              <%= link_to desbloquear_operacao_path(@operacao), data: { confirm: 'Tem certeza que deseja desbloquear esta operação?' },
                  class: "inline-flex items-center gap-2 px-4 h-10 rounded-button bg-primary hover:bg-primary-hover text-white text-sm font-medium transition-colors shadow-sm" do %>
                <i data-lucide="unlock" class="w-4 h-4"></i>
                Desbloquear
              <% end %>
            </div>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <!-- Card: Itens da Operação -->
  <div class="bg-muted rounded-card pt-5 px-3 pb-3 mb-6 md:mb-8">
    <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Itens da Operação</h3>
    <div class="bg-white rounded-card border border-border overflow-hidden">
      <% if @operacao.operacao_itens.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-border">
            <thead class="bg-muted/50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider w-24">Qtd</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Descrição</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">EAN</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              <% @operacao.operacao_itens.order(created_at: :asc).each do |item| %>
                <tr>
                  <td class="px-4 py-3 text-sm font-medium text-foreground"><%= item.qtd %></td>
                  <% if item.produto.present? %>
                    <td class="px-4 py-3 text-sm text-foreground text-blue-500 hover:text-blue-600 hover:underline"><%= link_to item.descricao, produto_path(item.produto) %></td>
                    <td class="px-4 py-3 text-sm text-foreground"><%= item.produto.ean.presence || "—" %></td>
                  <% else %>
                    <td class="px-4 py-3 text-sm text-foreground"><%= link_to item.descricao, new_produto_path(descricao: item.descricao), class: 'text-blue-500 hover:text-blue-600 hover:underline' %></td>
                    <td class="px-4 py-3 text-sm text-foreground">Produto não encontrado</td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="p-4 md:p-5">
          <p class="text-sm text-gray-500">Nenhum item nesta operação.</p>
        </div>
      <% end %>
    </div>
  </div>
</main>