<%= form_for(@operacao, html: { class: "space-y-6", role: "form" }) do |f| %>
  <% if @operacao.errors.any? %>
    <div class="text-sm rounded-button p-4 bg-error-light text-error-dark border border-error/20" role="alert">
      <div class="flex items-start gap-3">
        <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
        <div class="flex-1">
          <h3 class="font-medium mb-1">Confira os erros abaixo:</h3>
          <ul class="list-disc list-inside text-sm">
            <% @operacao.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Informações da OP -->
  <div>
    <h2 class="text-foreground text-lg font-bold mb-4 pb-2 border-b border-border">
      Informações da OP
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div>
        <%= f.label :numero, class: "block text-sm font-medium text-foreground mb-2" %>
        <%= f.number_field :numero, class: "w-full h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary", placeholder: "Número" %>
      </div>
      <div>
        <%= f.label :pedido_venda, "Pedido de Venda", class: "block text-sm font-medium text-foreground mb-2" %>
        <%= f.number_field :pedido_venda, class: "w-full h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary", placeholder: "Pedido" %>
      </div>
      <div>
        <%= f.label :qtd, "Quantidade", class: "block text-sm font-medium text-foreground mb-2" %>
        <%= f.number_field :qtd, class: "w-full h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary", placeholder: "Qtd", min: 0 %>
      </div>
    </div>
    <div class="mt-4">
      <%= f.label :observacao, "Observação", class: "block text-sm font-medium text-foreground mb-2" %>
      <%= f.text_area :observacao, rows: 2, class: "w-full px-3 py-2 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary", placeholder: "Observação" %>
    </div>
  </div>

  <!-- Itens da OP -->
  <div data-controller="operacao-itens" data-operacao-itens-url-value="<%= buscar_produtos_path %>">
    <h2 class="text-foreground text-lg font-bold mb-3">
      Itens da OP
    </h2>
    <div class="flex gap-2 mb-4 pb-4 border-b border-border">
      <input type="text"
             id="codigo-add"
             data-operacao-itens-target="codigoAddInput"
             data-action="keydown.enter->operacao-itens#addByCodigo"
             placeholder="Código do produto (Enter para adicionar)"
             class="flex-1 max-w-sm h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm"
             autocomplete="off">
      <button type="button"
              data-action="click->operacao-itens#addByCodigo"
              class="h-11 px-4 rounded-button bg-primary hover:bg-primary-hover text-white inline-flex items-center justify-center gap-2 shrink-0"
              title="Adicionar">
        <i data-lucide="plus" class="w-5 h-5"></i>
        <span class="text-sm font-medium">Adicionar</span>
      </button>
    </div>
    <div class="border border-border rounded-card overflow-hidden">
      <table class="min-w-full divide-y divide-border">
        <thead class="bg-muted/50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider w-24">Qtd</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-foreground uppercase tracking-wider">Descrição</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-foreground uppercase tracking-wider w-20">Ações</th>
          </tr>
        </thead>
        <tbody data-operacao-itens-target="container">
          <% @operacao.operacao_itens.each_with_index do |item, idx| %>
            <tr data-item-row class="border-t border-border">
              <td class="px-4 py-2">
                <%= number_field_tag "operacao[operacao_itens_attributes][#{idx}][qtd]", item.qtd, min: 1, class: "w-full h-10 px-3 rounded-button border border-border text-foreground focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm" %>
              </td>
              <td class="px-4 py-2">
                <%= text_field_tag "operacao[operacao_itens_attributes][#{idx}][descricao]", item.descricao, readonly: true, class: "w-full h-10 px-3 rounded-button border border-border bg-muted/30 text-foreground text-sm", placeholder: "—" %>
                <%= hidden_field_tag "operacao[operacao_itens_attributes][#{idx}][id]", item.id if item.persisted? %>
              </td>
              <td class="px-4 py-2 text-right">
                <% if item.persisted? %>
                  <%= hidden_field_tag "operacao[operacao_itens_attributes][#{idx}][_destroy]", "0", id: nil %>
                  <button type="button" data-action="click->operacao-itens#removeRow" class="p-2 text-foreground hover:text-red-600 hover:bg-red-50 rounded-card transition-colors" title="Remover">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                <% else %>
                  <button type="button" data-action="click->operacao-itens#removeRow" class="p-2 text-foreground hover:text-red-600 hover:bg-red-50 rounded-card transition-colors" title="Remover">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                  </button>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <template data-operacao-itens-target="rowTemplate">
      <tr data-item-row class="border-t border-border">
        <td class="px-4 py-2">
          <input type="number" name="operacao[operacao_itens_attributes][__INDEX__][qtd]" value="1" min="1" class="w-full h-10 px-3 rounded-button border border-border text-foreground focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm">
        </td>
        <td class="px-4 py-2">
          <input type="text" name="operacao[operacao_itens_attributes][__INDEX__][descricao]" readonly class="w-full h-10 px-3 rounded-button border border-border bg-muted/30 text-foreground text-sm" placeholder="—">
        </td>
        <td class="px-4 py-2 text-right">
          <button type="button" data-action="click->operacao-itens#removeRow" class="p-2 text-foreground hover:text-red-600 hover:bg-red-50 rounded-card transition-colors" title="Remover">
            <i data-lucide="trash-2" class="w-4 h-4"></i>
          </button>
        </td>
      </tr>
    </template>
  </div>

  <!-- Botão Submit -->
  <div class="flex justify-end gap-4 pt-4 border-t border-border">
    <%= link_to operacoes_path, class: 'px-6 py-2 rounded-button border border-border text-foreground font-medium hover:bg-muted/50 transition-colors' do %>
      Cancelar
    <% end %>
    <%= f.submit "Salvar", class: "px-6 py-2 rounded-button bg-primary hover:bg-primary-hover text-white font-medium transition-colors shadow-sm" %>
  </div>
<% end %>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const form = document.querySelector("form");
    if (form) {
      form.addEventListener("keydown", function(event) {
        if (event.key === "Enter" && event.target.tagName !== "BUTTON" && event.target.type !== "submit") {
          event.preventDefault();
        }
      });
    }
  });
</script>