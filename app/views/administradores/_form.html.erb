<%= form_for(@administrador, html: { class: "space-y-6", role: "form" }) do |f| %>
  <% if @administrador.errors.any? %>
    <div class="text-sm rounded-button p-4 bg-error-light text-error-dark border border-error/20" role="alert">
      <div class="flex items-start gap-3">
        <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
        <div class="flex-1">
          <h3 class="font-medium mb-1">Confira os erros abaixo:</h3>
          <ul class="list-disc list-inside text-sm">
            <% @administrador.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Informações Básicas -->
  <div>
    <h2 class="text-foreground text-lg font-bold mb-4 pb-2 border-b border-border">
      Informações Básicas
    </h2>
    <div class="space-y-6">
      <div>
        <%= f.label :nome, class: "block text-sm font-medium text-foreground mb-2" %>
        <%= f.text_field :nome, class: "w-full h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary", required: true %>
      </div>
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-foreground mb-2" %>
        <%= f.email_field :email, class: "w-full h-11 px-3 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary", required: true %>
      </div>
      <div>
        <%= f.label :senha, class: "block text-sm font-medium text-foreground mb-2" %>
        <div class="relative">
          <%= f.password_field :senha, class: "w-full h-11 px-3 pr-12 rounded-button border border-border text-foreground focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary", id: "administrador_senha", required: true %>
          <button type="button" onclick="togglePassword()" class="absolute inset-y-0 right-0 flex items-center pr-3 text-foreground hover:text-primary transition-colors">
            <i data-lucide="eye" id="eye-icon" class="w-5 h-5"></i>
            <i data-lucide="eye-off" id="eye-off-icon" class="w-5 h-5 hidden"></i>
          </button>
        </div>
        <p class="mt-1 text-xs text-gray-500">Clique no ícone do olho para mostrar/ocultar a senha</p>
      </div>
    </div>
  </div>

  <!-- Botão Submit -->
  <div class="flex justify-end gap-4 pt-4 border-t border-border">
    <%= link_to administradores_path, class: 'px-6 py-2 rounded-button border border-border text-foreground font-medium hover:bg-muted/50 transition-colors' do %>
      Cancelar
    <% end %>
    <%= f.submit "Salvar", class: "px-6 py-2 rounded-button bg-primary hover:bg-primary-hover text-white font-medium transition-colors shadow-sm" %>
  </div>
<% end %>

<script>
  function togglePassword() {
    const passwordField = document.getElementById('administrador_senha');
    const eyeIcon = document.getElementById('eye-icon');
    const eyeOffIcon = document.getElementById('eye-off-icon');

    if (passwordField.type === 'password') {
      passwordField.type = 'text';
      eyeIcon.classList.add('hidden');
      eyeOffIcon.classList.remove('hidden');
    } else {
      passwordField.type = 'password';
      eyeIcon.classList.remove('hidden');
      eyeOffIcon.classList.add('hidden');
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('form');
    if (form) {
      form.addEventListener('keydown', function(event) {
        if (event.key === 'Enter' && event.target.tagName !== 'BUTTON' && event.target.type !== 'submit') {
          event.preventDefault();
        }
      });
    }
  });
</script>