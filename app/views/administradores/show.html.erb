<main class="flex-1 lg:ml-64 p-4 md:p-5 bg-white min-h-screen overflow-x-hidden">
  <!-- Mobile Header -->
  <div class="lg:hidden flex items-center justify-between mb-6 bg-muted rounded-card p-4">
    <button onclick="toggleSidebar()" aria-label="Abrir menu" class="p-2 rounded-lg hover:bg-gray-200 cursor-pointer transition-all duration-200">
      <i data-lucide="menu" class="w-6 h-6 text-foreground"></i>
    </button>
    <h1 class="text-foreground text-lg font-bold">Confer</h1>
    <div class="w-10"></div>
  </div>

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6 md:mb-8">
    <div class="flex items-center gap-4">
      <%= link_to administradores_path, class: 'inline-flex items-center gap-2 px-4 py-2 text-foreground bg-white border border-border rounded-button hover:bg-muted/50 transition-colors' do %>
        <i data-lucide="arrow-left" class="w-5 h-5"></i>
        Voltar
      <% end %>
      <div>
        <h1 class="text-foreground text-2xl md:text-3xl font-bold mb-1"><%= @administrador.nome %></h1>
        <p class="text-foreground text-sm text-gray-500">Detalhes do administrador</p>
      </div>
    </div>
    <%= link_to edit_administrador_path(@administrador), class: 'inline-flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary-hover text-white rounded-button font-medium transition-colors shadow-sm' do %>
      <i data-lucide="pencil" class="w-5 h-5"></i>
      Editar
    <% end %>
  </div>

  <!-- Cards -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6 md:mb-8">
    <!-- Card: Informações Básicas -->
    <div class="bg-muted rounded-card pt-5 px-3 pb-3">
      <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Informações Básicas</h3>
      <div class="bg-white rounded-card p-4 md:p-5 border border-border">
        <dl class="space-y-4">
          <div>
            <dt class="text-sm font-medium text-gray-500">Nome</dt>
            <dd class="mt-1 text-sm font-medium text-foreground"><%= @administrador.nome %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Email</dt>
            <dd class="mt-1 text-sm text-foreground">
              <a href="mailto:<%= @administrador.email %>" class="text-primary hover:underline">
                <%= @administrador.email %>
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Tipo de Acesso</dt>
            <dd class="mt-1">
              <% if @administrador.is_admin? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary">
                  ADMINISTRADOR
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-muted text-foreground">
                  USUÁRIO
                </span>
              <% end %>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Card: Grupos de Acesso -->
    <div class="bg-muted rounded-card pt-5 px-3 pb-3">
      <h3 class="text-foreground text-lg font-bold ml-3 mb-4">Grupos de Acesso</h3>
      <div class="bg-white rounded-card p-4 md:p-5 border border-border">
        <% if @administrador.administrador_grupo_acessos.any? %>
          <div class="space-y-2">
            <% @administrador.administrador_grupo_acessos.each do |aga| %>
              <div class="flex items-center justify-between p-3 bg-muted/30 rounded-card">
                <span class="text-sm font-medium text-foreground">
                  <%= aga.grupo_acesso.nome %>
                </span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">Nenhum grupo de acesso atribuído</p>
        <% end %>
      </div>
    </div>
  </div>
</main>
